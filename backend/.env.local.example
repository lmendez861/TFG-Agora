APP_ENV=dev
APP_DEBUG=1
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_dev.sqlite"
MAILER_DSN="smtp://usuario:clave@smtp.centro.edu:587"
APP_MAIL_FROM="Coordinacion Practicas <practicas@centro.edu>"

# URL publica o local del backend. Cambiala si accedes desde otra maquina
# mediante IP o dominio.
DEFAULT_URI="http://127.0.0.1:8000"

# Regex amplia para pruebas en local, LAN o dominio propio.
# Restringela mas antes de un despliegue real.
CORS_ALLOW_ORIGIN='^https?://[A-Za-z0-9.-]+(:[0-9]+)?$'
